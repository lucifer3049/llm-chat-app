# ============================================================
#  LLM Chat Web App — environment template
#  Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- App ----
APP_ENV=development            # development | production
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) ----
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=chatdb
POSTGRES_HOST=db               # service name in docker-compose
POSTGRES_PORT=5432
# Full SQLAlchemy URL is assembled from the parts above by config.py,
# but you may override it explicitly here if needed:
# DATABASE_URL=postgresql+psycopg://chat:password@db:5432/chatdb

# ---- JWT / security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=120

# ---- Super admin seed (invariant I-1, fail-fast if missing) ----
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-strong-admin-password

# ---- LLM provider ----
# Day 4 ships a deterministic mock so chat works with no API key.
# Switch to `groq` once the Groq adapter lands (Day 5) and set GROQ_API_KEY.
LLM_PROVIDER=mock              # mock | groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TITLE_MODEL=llama-3.1-8b-instant
